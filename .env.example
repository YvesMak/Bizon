# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bizon_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Facturation
INVOICE_STORAGE_PATH=./storage/invoices

# Mobile Money (à adapter selon le provider)
MOBILE_MONEY_API_URL=https://api.mobilemoney.provider/v1
MOBILE_MONEY_API_KEY=your_mobile_money_api_key
