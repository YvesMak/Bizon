# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bizon_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Facturation
INVOICE_STORAGE_PATH=./storage/invoices

# Mobile Money (à adapter selon le provider)
MOBILE_MONEY_API_URL=https://api.mobilemoney.provider/v1
MOBILE_MONEY_API_KEY=your_mobile_money_api_key

# URL publique de l'app (redirections de paiement + webhooks)
APP_BASE_URL=http://localhost:3000

# Nettoyage des commandes client non payées
ORDER_DRAFT_TTL_MINUTES=30
CLEANUP_INTERVAL_MINUTES=10

# Flutterwave (agrégateur : Mobile Money MTN/Orange + cartes)
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxx-X
FLW_ENCRYPTION_KEY=FLWSECK_TESTxxxxx
# Secret hash défini dans le dashboard Flutterwave (Settings → Webhooks)
FLW_WEBHOOK_HASH=
FLW_BASE_URL=https://api.flutterwave.com/v3

# Notifications push (Web Push / VAPID)
# Générer une paire avec : npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@bizon.cm

# Provider de paiement actif : 'campay' (Mobile Money Cameroun) ou 'flutterwave'
PAYMENT_PROVIDER=campay
# Campay (Mobile Money MTN/Orange) — identifiants d'application du dashboard Campay
CAMPAY_USERNAME=
CAMPAY_PASSWORD=
# Sandbox : https://demo.campay.net · Production : https://www.campay.net
CAMPAY_BASE_URL=https://demo.campay.net
CAMPAY_WEBHOOK_KEY=
